{
    "name": "basta-kape-server",
    "version": "1.0.0",
    "description": "",
    "main": "index.js",
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "dev": "nodemon -r tsconfig-paths/register --exec ts-node src/server.ts",
        "build": "tsc && tsc-alias",
        "start": "node dist/server.js",
        "format": "prettier --write \"src/**/*.ts\"",
        "lint": "eslint src/**/*.ts",
        "lint:fix": "eslint src/**/*.ts --fix",
        "prepare": "husky",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:seed": "prisma db seed",
        "db:reset": "prisma migrate reset "
    },
    "keywords": [],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "dependencies": {
        "@asteasolutions/zod-to-openapi": "^8.5.0",
        "@types/bcryptjs": "^2.4.6",
        "@types/jsonwebtoken": "^9.0.10",
        "bcryptjs": "^3.0.3",
        "cors": "^2.8.6",
        "dotenv": "^17.4.2",
        "express": "^5.2.1",
        "express-rate-limit": "^8.5.2",
        "helmet": "^8.2.0",
        "jsonwebtoken": "^9.0.3",
        "multer": "^2.1.1",
        "pino": "^10.3.1",
        "pino-http": "^11.0.0",
        "swagger-ui-express": "^5.0.1",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@eslint/js": "^10.0.1",
        "@prisma/client": "^6.19.3",
        "@types/cors": "^2.8.19",
        "@types/express": "^5.0.6",
        "@types/multer": "^2.1.0",
        "@types/node": "^25.9.1",
        "@types/supertest": "^7.2.0",
        "@types/swagger-ui-express": "^4.1.8",
        "eslint": "^10.4.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-prettier": "^5.5.6",
        "husky": "^9.1.7",
        "lint-staged": "^17.0.7",
        "nodemon": "^3.1.14",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.8.3",
        "prisma": "^6.19.3",
        "supertest": "^7.2.2",
        "ts-node": "^10.9.2",
        "ts-node-dev": "^2.0.0",
        "tsc-alias": "^1.8.17",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.60.0",
        "vite-tsconfig-paths": "^6.1.1",
        "vitest": "^4.1.8"
    },
    "lint-staged": {
        "*.ts": [
            "prettier --write",
            "eslint --fix"
        ]
    },
    "prisma": {
        "schema": "prisma/schema",
        "seed": "ts-node prisma/seed.ts"
    }
}
