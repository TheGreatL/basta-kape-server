generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model StoreSetting {
  id            String   @id @default(uuid())
  storeName     String   @default("Basta Kape")
  address       String   @default("50 K-1st, Quezon City, Metro Manila")
  contactNumber String?
  openingTime   String   @default("07:00") // HH:MM
  closingTime   String   @default("21:00") // HH:MM
  vatRate       Float    @default(12.0)    // Standard PH VAT (12%)
  serviceCharge Float    @default(0.0)
  
  updatedAt     DateTime @updatedAt
}
