enum OrderStatus {
  PENDING
  PREPARING
  READY
  COMPLETED
  CANCELLED
}

enum OrderType {
  DINE_IN
  TAKE_OUT
  DELIVERY
}

enum OrderSource {
  POS
  MOBILE_APP
  WEBSITE
  DELIVERY_PARTNER
}

enum PaymentMethod {
  CASH
  GCASH
  PAYMAYA
  CREDIT_CARD
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
}

// 1. RegisterShift: Cashier drawer sessions
model RegisterShift {
  id            String    @id @default(uuid())
  cashierId     String
  cashier       User      @relation(fields: [cashierId], references: [id])
  openedAt      DateTime  @default(now())
  closedAt      DateTime?
  startBalance  Float     @default(0)
  endBalance    Float?
  actualBalance Float?
  notes         String?
  orders        Order[]
}

// 2. Order: Master order entity
model Order {
  id               String               @id @default(uuid())
  queueNumber      String?              // E.g. #042 printed on cup label
  buzzerId         String?              // Pager/buzzer number
  status           OrderStatus          @default(PENDING)
  orderType        OrderType            @default(DINE_IN)
  orderSource      OrderSource          @default(POS)
  notes            String?
  
  // Pricing totals
  subtotal         Float                @default(0)
  taxAmount        Float                @default(0)
  discountAmount   Float                @default(0)
  netTotal         Float                @default(0)
  
  // Customer details (Registered or walk-in name for sticker)
  customerId       String?
  customer         Customer?            @relation(fields: [customerId], references: [id])
  customerName     String?              // Custom walk-in customer name
  
  // Cashier shift assignment
  cashierSessionId String?
  cashierSession   RegisterShift?       @relation(fields: [cashierSessionId], references: [id])
  
  items            OrderItem[]
  statusHistory    OrderStatusHistory[]
  payments         OrderPayment[]
  voidLogs         OrderVoidLog[]
  discounts        OrderDiscount[]
  
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?
}

// 3. OrderItem: Individual items in the order
model OrderItem {
  id               String               @id @default(uuid())
  orderId          String
  order            Order                @relation(fields: [orderId], references: [id])
  productVariantId String
  variant          ProductVariant       @relation(fields: [productVariantId], references: [id])
  
  quantity         Int                  @default(1)
  unitPrice        Float                @default(0)
  totalPrice       Float                @default(0)
  notes            String?              // Item-specific instructions (e.g. "extra hot")
  
  modifiers        OrderItemModifier[]
  
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt
  deletedAt        DateTime?
}

// 4. ModifierGroup: Customize options configurations (e.g. "Sweetness Level", "Add-ons")
model ModifierGroup {
  id          String           @id @default(uuid())
  name        String
  isRequired  Boolean          @default(false)
  minSelect   Int              @default(0)
  maxSelect   Int              @default(1)
  options     ModifierOption[]
  
  // Many-to-many relationship with Product
  products    Product[]
  
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  deletedAt   DateTime?
}

// 5. ModifierOption: Choice selection and price adjustment (e.g. "Oat Milk" (+$0.50))
model ModifierOption {
  id              String               @id @default(uuid())
  modifierGroupId String
  group           ModifierGroup        @relation(fields: [modifierGroupId], references: [id])
  name            String
  price           Float                @default(0)
  
  orderItemModifiers OrderItemModifier[]
  cartModifiers      CustomerCartModifier[]
  
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  deletedAt       DateTime?
}

// 6. OrderItemModifier: Selected customizations mapped to order item
model OrderItemModifier {
  id               String         @id @default(uuid())
  orderItemId      String
  orderItem        OrderItem      @relation(fields: [orderItemId], references: [id])
  modifierOptionId String
  modifierOption   ModifierOption @relation(fields: [modifierOptionId], references: [id])
  price            Float          @default(0) // Captures price snapshot at purchase
  
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
}

// 7. OrderPayment: Payment transaction tracking
model OrderPayment {
  id                    String        @id @default(uuid())
  orderId               String
  order                 Order         @relation(fields: [orderId], references: [id])
  paymentMethod         PaymentMethod @default(CASH)
  paymentStatus         PaymentStatus @default(PENDING)
  amount                Float         @default(0)
  
  // GCash / Digital verification
  gcashReferenceNumber  String?
  paymentProofPhoto     String?       // Path/URL to GCash screenshot
  
  // Cash payment specific
  amountTendered        Float?
  amountChange          Float?
  
  createdAt             DateTime      @default(now())
  updatedAt             DateTime      @updatedAt
}

// 8. OrderStatusHistory: Live status logging
model OrderStatusHistory {
  id          String      @id @default(uuid())
  orderId     String
  order       Order       @relation(fields: [orderId], references: [id])
  status      OrderStatus
  notes       String?
  changedById String?
  changedBy   User?       @relation(fields: [changedById], references: [id])
  
  createdAt   DateTime    @default(now())
}

// 9. OrderVoidLog: Loss prevention audit logs
model OrderVoidLog {
  id          String    @id @default(uuid())
  orderId     String
  order       Order     @relation(fields: [orderId], references: [id])
  reason      String
  voidedById  String
  voidedBy    User      @relation(fields: [voidedById], references: [id])
  
  createdAt   DateTime  @default(now())
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
}

model Discount {
  id          String         @id @default(uuid())
  name        String         // E.g., "Senior Citizen", "PWD", "Soft Launch 10% Off"
  type        DiscountType   @default(PERCENTAGE)
  value       Float          // E.g. 20.00 for percentage or 50.00 for fixed
  code        String?        @unique // E.g. WELCOME10
  isActive    Boolean        @default(true)
  
  orderDiscounts OrderDiscount[]
  
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  deletedAt   DateTime?
}

model OrderDiscount {
  id            String    @id @default(uuid())
  orderId       String
  order         Order     @relation(fields: [orderId], references: [id])
  discountId    String
  discount      Discount  @relation(fields: [discountId], references: [id])
  amount        Float     // The actual monetary value discounted
  
  // Philippine BIR SC/PWD Compliance Fields
  referenceId   String?   // SC/PWD Card ID number (e.g. "SC-12345")
  referenceName String?   // SC/PWD cardholder name
  
  createdAt     DateTime  @default(now())
}
